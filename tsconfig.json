/* To learn more about Typescript configuration file: https://www.typescriptlang.org/docs/handbook/tsconfig-json.html. */
/* To learn more about Angular compiler options: https://angular.dev/reference/configs/angular-compiler-options. */
{
  "compileOnSave": false,
  "compilerOptions": {
    "strict": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "importHelpers": true,
    "target": "ES2022",
    "module": "preserve",
    "paths": {
      "angular-rx-submit": ["./dist/lib"]
    },
    // Additional configuration for explicit type imports management
    "verbatimModuleSyntax": true,
    // Additional configuration for better interoperability with tools
    "erasableSyntaxOnly": true,
    // Additional configuration for type safety
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true
  },
  "angularCompilerOptions": {
    "enableI18nLegacyMessageIdFormat": false,
    "strictInjectionParameters": true,
    "strictInputAccessModifiers": true,
    "strictTemplates": true,
    // Additional configuration to enforce standalone components
    "strictStandalone": true,
    // Additional configuration to enforce Angular diagnostics as compilation errors
    "extendedDiagnostics": {
      "defaultCategory": "error"
    }
  },
  "files": [],
  "references": [
    {
      "path": "./lib/tsconfig.lib.json"
    },
    {
      "path": "./lib/tsconfig.spec.json"
    },
    {
      "path": "./app-demo/tsconfig.app.json"
    },
    {
      "path": "./app-demo/tsconfig.spec.json"
    }
  ]
}
