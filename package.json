{
  "name": "angular-rx-submit",
  "version": "21.2.0",
  "scripts": {
    "ng": "ng",
    "start-demo": "ng serve app-demo",
    "build": "ng build lib",
    "test": "ng test lib --watch=false && ng test app-demo --watch=false",
    "test-lib-watch": "ng test lib",
    "test-app-demo": "ng test app-demo --watch=false",
    "lint": "ng lint",
    "release:patch": "VERSION=patch npm run release",
    "release:minor": "VERSION=minor npm run release",
    "release:major": "VERSION=major npm run release",
    "release": "if test $VERSION; then npm run build && cd lib && npm version $VERSION --no-git-tag-version && git add package.json && cd .. && git commit -m \"release\" && npm version $VERSION && git push; fi",
    "publish-release": "git push origin v$npm_package_version"
  },
  "private": true,
  "packageManager": "npm@11.10.0",
  "dependencies": {
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.4",
    "rxjs": "~7.8.0",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular/build": "^21.2.2",
    "@angular/cli": "^21.2.2",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/compiler-cli": "^21.2.4",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.4",
    "@eslint/js": "^10.0.1",
    "angular-eslint": "^21.3.1",
    "eslint": "^10.0.3",
    "jsdom": "^29.0.0",
    "ng-packagr": "^21.2.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.57.1",
    "vitest": "^4.1.0"
  }
}
